# Required configuration
# The service also accepts BUILDIUM_CLIENT_ID / BUILDIUM_CLIENT_SECRET.
BUILDIUM_KEY=your_buildium_client_id
BUILDIUM_SECRET=your_buildium_client_secret

# The service also accepts SPREADSHEET_ID and SHEET_TITLE.
SHEET_ID=your_spreadsheet_id
WORKSHEET_NAME=Collections Status

# Optional: Override SHEET_ID for safe testing
# TEST_SHEET_ID=test_spreadsheet_id

# Optional: Sheet structure
HEADER_ROW=1
DATA_ROW=2

# Optional: Server port
PORT=8080

# Optional: Buildium API configuration
# The service also accepts BUILDIUM_BASE_URL.
BUILDIUM_API_URL=https://api.buildium.com/v1

# Optional: Google Sheets credentials
# GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account.json

# Optional: Timeouts (seconds)
BAL_TIMEOUT=60
LEASE_TIMEOUT=60
TENANT_TIMEOUT=60
TENANT_SLEEP_MS=250

# Optional: Distributed lock settings (for concurrent sync protection)
# SYNC_LOCK_SHEET=_sync_lock
# SYNC_LOCK_TIMEOUT_SECONDS=30
# SYNC_LOCK_STALE_SECONDS=300

# Optional: Write reliability settings
# SYNC_WRITE_CHUNK_SIZE=200
# SYNC_VERIFY_CHECKSUMS=false
# SYNC_MAX_RETRIES=2
# SYNC_RETRY_BACKOFF_MS=2000

# Optional: Enable atomic (locked) upsert (default: false for backwards compat)
# SYNC_ENABLE_ATOMIC=false
