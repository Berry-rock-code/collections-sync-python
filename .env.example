# Required configuration
BUILDIUM_KEY=your_buildium_client_id
BUILDIUM_SECRET=your_buildium_client_secret
SHEET_ID=your_spreadsheet_id
WORKSHEET_NAME=Collections Status

# Optional: Override SHEET_ID for safe testing
# TEST_SHEET_ID=test_spreadsheet_id

# Optional: Sheet structure
HEADER_ROW=1
DATA_ROW=2

# Optional: Server port
PORT=8080

# Optional: Buildium API configuration
BUILDIUM_API_URL=https://api.buildium.com/v1

# Optional: Google Sheets credentials
# GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account.json

# Optional: Timeouts (seconds)
BAL_TIMEOUT=60
LEASE_TIMEOUT=60
TENANT_TIMEOUT=60
TENANT_SLEEP_MS=250
